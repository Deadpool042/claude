{
  "name": "site-factory-monorepo",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "core-js",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "docker compose up -d traefik db && pnpm -C site-factory dev",
    "up": "docker compose up -d traefik db",
    "down": "docker compose down",
    "lint": "pnpm -C site-factory lint",
    "typecheck": "pnpm -C site-factory typecheck",
    "validate:spec": "pnpm spec:audit:strict && pnpm spec:check",
    "validate": "pnpm spec:audit:strict && pnpm spec:check && pnpm -C site-factory typecheck && pnpm -C site-factory test",
    "db:migrate": "pnpm -C site-factory prisma:migrate",
    "db:seed": "pnpm -C site-factory prisma:seed",
    "spec:audit": "node scripts/spec-audit-step2.mjs",
    "spec:audit:strict": "node scripts/spec-audit-step2.mjs --strict",
    "spec:sync": "node scripts/sync-spec-to-app.mjs",
    "spec:check": "node scripts/sync-spec-to-app.mjs --check",
    "compose:validate": "docker compose config",
    "theme:verify": "node scripts/verify-wp-block-theme.mjs",
    "sf:theme:watch": "node scripts/watch-sf-tt5-theme.mjs"
  }
}
