  "economicRules": {
    "basePricingByCategory": {
      "CAT0": {
        "type": "FROM",
        "from": 1290
      },
      "CAT1": {
        "type": "FROM",
        "from": 1800
      },
      "CAT2": {
        "type": "RANGE",
        "min": 3500,
        "max": 5200
      },
      "CAT3": {
        "type": "RANGE",
        "min": 4500,
        "max": 8000
      },
      "CAT4": {
        "type": "RANGE",
        "min": 7000,
        "max": 15000
      }
    },
    "maintenancePricingByCategory": {
      "CAT0": {
        "monthly": 29,
        "scopeSummary": "Mises à jour de sécurité, monitoring basique, sauvegarde hebdo"
      },
      "CAT1": {
        "monthly": 59,
        "scopeSummary": "CAT0 + correctifs mineurs, support email, sauvegarde journalière"
      },
      "CAT2": {
        "monthly": 129,
        "scopeSummary": "CAT1 + supervision e-commerce, optimisation légère, SLA standard"
      },
      "CAT3": {
        "monthly": 249,
        "scopeSummary": "CAT2 + supervision connecteurs, assistance prioritaire, SLA renforcé"
      },
      "CAT4": {
        "monthly": 490,
        "scopeSummary": "CAT3 + run avancé, astreinte planifiée, gouvernance mensuelle"
      }
    },
    "annexFees": {
      "deploymentSetupFee": {
        "oneTime": 390,
        "scopeSummary": "CI/CD, configuration environnements, check mise en production"
      },
      "domainCostRange": {
        "yearlyMin": 12,
        "yearlyMax": 60
      },
      "hostingCostRange": {
        "monthlyMin": 18,
        "monthlyMax": 220
      },
      "emailProviderCostRange": {
        "monthlyMin": 0,
        "monthlyMax": 90
      },
      "storageCostRange": {
        "monthlyMin": 0,
        "monthlyMax": 120
      }
    },
    "marketPositioning": {
      "label": "local / Saint-Étienne",
      "guardrails": {
        "smallUxThemeFeaturesMaxShareOfBaseBuild": 0.12,
        "smallUxThemeFeaturesMaxAbsolute": 450,
        "majorCommerceModulesMinShareOfBaseBuild": 0.25,
        "preventSmallUxPricingNearMajorModules": true
      }
    },
    "pluginVsModuleDecision": {
      "preferPluginIntegrationWhen": {
        "stablePluginOrAppExists": true,
        "maxPluginMonthlyCost": 120,
        "forbiddenEcosystemStates": [
          "FRAGMENTED"
        ]
      },
      "fallbackToFrameworkModuleWhen": {
        "businessValue": "HIGH",
        "reusability": "HIGH",
        "pluginEcosystem": [
          "FRAGMENTED",
          "EXPENSIVE",
          "INTEGRATION_COMPLEX"
        ]
      }
    },
    "preferPluginWhen": {
      "pluginAvailability": "HIGH",
      "pluginCostLowerThanModuleBuild": true,
      "maintenanceRisk": "LOW"
    },
    "allowFrameworkModuleWhen": {
      "businessValue": "HIGH",
      "reusability": "HIGH",
      "pluginEcosystem": [
        "FRAGMENTED",
        "EXPENSIVE",
        "INTEGRATION_COMPLEX"
      ]
    },
    "customAppWhen": {
      "cmsCapabilityUnsupported": true,
      "clientRefusesCms": true,
      "projectIsSaaSOrCustomPlatform": true,
      "customBackendRequired": true
    },
    "pricingCoherence": {
      "themeFeaturesCannotBeFrameworkModule": true,
      "modulePriceMustNotExceedTargetCategoryBaseOffer": true,
      "smallUxThemeFeaturesMustStayBelowMajorCommerceModules": true,
      "pluginWrapperMustBePluginIntegration": true
    }
  },
  "invariants": {
    "darkModeMustAlwaysBeThemeFeature": true,
    "moduleCountMin": 10,
    "moduleCountMax": 15,
    "idsAreImmutable": true
  },
  "projectFlagsSchema": [
    "clientRefusesCms",
    "projectIsSaaS",
    "requiresCustomBackend",
    "estimatedPluginMonthlyCost",
    "pluginAvailability",
    "pluginCostLessThanModule",
    "pluginMaintenanceRisk",
    "businessValue",
    "reusability",
    "pluginEcosystem",
    "contentWorkflowPreference"
  ],
  "decisionOutputPipeline": [
    "project_requirements",
    "recommended_CMS",
    "recommended_plugins",
    "activated_modules",
    "recommended_content_workflow",
    "recommended_stack_profile",
    "technical_stack",
    "estimated_cost"
  ],
  "customStackProfiles": [
    "CUSTOM_STACK_LIGHT",
    "CUSTOM_STACK_ENTERPRISE"
  ]
